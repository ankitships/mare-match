# ===== LLM Provider =====
# One of these is required for real analysis. Without them the app runs in mock/fixture mode.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai                  # "openai" | "anthropic"
LLM_MODEL=gpt-4o-mini                # e.g. gpt-4o-mini, gpt-4o, claude-3-5-sonnet-latest

# ===== Firecrawl (web crawl/extraction) =====
FIRECRAWL_API_KEY=

# ===== Supabase (optional) =====
# If unset, the app uses file-based JSON storage under data/storage/
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===== App =====
NEXT_PUBLIC_APP_URL=http://localhost:3000
USE_FIXTURES=0                       # 1 = never call external APIs (fast demo mode)
